@inherits LayoutComponentBase
@inject UserSession Session
@inject NavigationManager Nav

<div class="app-shell">
    @if (Session.IsAuthenticated)
    {
        <header class="top-bar">
            <span class="app-title">Управление заявками</span>
            <nav class="top-nav">
                <a href="/orders" class="nav-link @(Nav.Uri.Contains("/orders") ? "active" : "")">Заявки</a>
                <a href="/map"    class="nav-link @(Nav.Uri.Contains("/map")    ? "active" : "")">Карта</a>
            </nav>
            <span class="role-badge">@Session.Role</span>
            <button class="btn-logout" @onclick="ChangeRole">Сменить роль</button>
            <button class="btn-logout" @onclick="Logout">Выйти</button>
        </header>
    }
    <main>
        @Body
    </main>
</div>

@code {
    void ChangeRole()
    {
        Session.Role = "";
        Nav.NavigateTo("/", forceLoad: false);
    }

    void Logout()
    {
        Session.Role = "";
        Session.IsPasswordVerified = false;
        Nav.NavigateTo("/login");
    }
}
