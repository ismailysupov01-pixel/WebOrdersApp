@inherits LayoutComponentBase
@inject UserSession Session
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="app-shell">
    @if (Session.IsAuthenticated)
    {
        <header class="top-bar">
            <span class="app-title">Заявки</span>
            <nav class="top-nav">
                <a href="/orders" class="nav-link @(Nav.Uri.Contains("/orders") ? "active" : "")">📋 Заявки</a>
                <a href="/map"    class="nav-link @(Nav.Uri.Contains("/map")    ? "active" : "")">🗺 Карта</a>
            </nav>
            <div class="top-bar-right">
                <span class="user-name-badge" title="@Session.Role">@Session.Name</span>
                <button class="btn-logout" @onclick="Logout">Выйти</button>
            </div>
        </header>
    }
    <main>
        @Body
    </main>
</div>

@code {
    async Task Logout()
    {
        await JS.InvokeVoidAsync("clearSession");
        Session.Role = "";
        Session.Name = "";
        Session.Login = "";
        Session.IsPasswordVerified = false;
        Nav.NavigateTo("/login");
    }
}
