@page "/orders"
@implements IAsyncDisposable
@inject GoogleSheetsService Sheets
@inject UserSession Session
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (!Session.IsAuthenticated)
{
    Nav.NavigateTo("/");
    return;
}

<div class="orders-page">
    <div class="orders-header">
        <h2>Заявки</h2>
        <div class="header-actions">
            <div class="date-filter-wrap">
                <input type="date" value="@(_filterDate?.ToString("yyyy-MM-dd"))"
                       @oninput="OnFilterDateChanged" class="form-input date-filter-input"
                       title="Фильтр по дате"/>
                @if (_filterDate.HasValue)
                {
                    <button class="btn-clear-date" @onclick="ClearDateFilter" title="Сбросить">✕</button>
                }
            </div>
            <button class="btn-refresh" @onclick="LoadOrders" disabled="@_loading">
                @(_loading ? "Загрузка..." : "Обновить")
            </button>
            @if (Session.Role == "Оператор")
            {
                <button class="btn-add" @onclick="OpenAdd">+ Новая заявка</button>
            }
        </div>
    </div>

    @if (_error != null)
    {
        <div class="alert-error">@_error</div>
    }

    @if (_orders == null)
    {
        <div class="loading-text">Загрузка заявок...</div>
    }
    else if (Filtered.Count == 0)
    {
        <div class="loading-text">Заявок нет.</div>
    }
    else
    {
        @if (_checkedRows.Count > 0)
        {
            <div class="bulk-bar">
                <span class="bulk-count">Выбрано: <b>@_checkedRows.Count</b></span>
                <select @bind="_bulkStatus" class="form-input bulk-select">
                    <option value="">— Выберите статус —</option>
                    <option value="@OrderStatus.New">@OrderStatus.New</option>
                    <option value="@OrderStatus.Completed">@OrderStatus.Completed</option>
                    <option value="@OrderStatus.Cancelled">@OrderStatus.Cancelled</option>
                </select>
                <button class="btn-save bulk-apply" @onclick="ApplyBulkStatus"
                        disabled="@(_bulkSaving || string.IsNullOrEmpty(_bulkStatus))">
                    @if (_bulkSaving)
                    { <span>@_bulkProgress / @_checkedRows.Count...</span> }
                    else
                    { <span>Применить</span> }
                </button>
                <button class="btn-cancel bulk-clear" @onclick="ClearChecked">✕ Снять</button>
                @if (_bulkError != null)
                {
                    <span class="bulk-error">@_bulkError</span>
                }
            </div>
        }
        <div class="table-wrapper">
            <table class="orders-table">
                <thead>
                    <tr>
                        <th @onclick:stopPropagation="true" style="width:36px">
                            <input type="checkbox"
                                   checked="@(Filtered.Count > 0 && _checkedRows.Count == Filtered.Count)"
                                   @onchange="ToggleAll" />
                        </th>
                        <th>#</th>
                        <th>Адрес</th>
                        <th>Телефон</th>
                        <th>Сумма</th>
                        <th>Дата</th>
                        <th>Автор</th>
                        <th>Статус</th>
                        <th>Исполнитель</th>
                        <th>Комментарии</th>
                        <th>2ГИС</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Filtered)
                    {
                        <tr class="@RowClass(o.Status) @(_checkedRows.Contains(o.RowIndex) ? "row-checked" : "")"
                            @onclick="() => OpenDetail(o)" style="cursor:pointer">
                            <td @onclick:stopPropagation="true">
                                <input type="checkbox"
                                       checked="@_checkedRows.Contains(o.RowIndex)"
                                       @onchange="() => ToggleCheck(o.RowIndex)" />
                            </td>
                            <td>@o.OrderNumber</td>
                            <td>@o.Address</td>
                            <td @onclick:stopPropagation="true">
                                @if (!string.IsNullOrEmpty(o.Phone))
                                {
                                    <a href="https://wa.me/@(WaPhone(o.Phone))" target="_blank" class="wa-link">@o.Phone</a>
                                }
                            </td>
                            <td>@o.Amount</td>
                            <td>@o.Date</td>
                            <td><span class="author-badge">@o.Author</span></td>
                            <td><span class="status-badge @StatusClass(o.Status)">@o.Status</span></td>
                            <td><span class="executor-badge @(string.IsNullOrEmpty(o.Executor) ? "" : "executor-filled")">@o.Executor</span></td>
                            <td>@o.Comments</td>
                            <td @onclick:stopPropagation="true">
                                @if (!string.IsNullOrEmpty(o.TwoGisLink))
                                {
                                    <a href="@o.TwoGisLink" target="_blank" class="link-2gis">Открыть</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Add Order Modal -->
@if (_showAdd)
{
    <div class="modal-overlay" @onclick="CloseAdd">
        <div class="modal-box" @onclick:stopPropagation="true">
            <h3>Новая заявка</h3>
            <div class="form-group">
                <label>Адрес *</label>
                <input value="@_newOrder.Address"
                       @oninput="OnAddressInput"
                       class="form-input" placeholder="Улица, дом"/>
            </div>
            <div class="form-group">
                <label>Телефон</label>
                <input id="phone-mask-input" type="tel"
                       value="@_phoneInput"
                       @oninput="OnPhoneInput"
                       class="form-input" placeholder="+7"
                       maxlength="16"/>
            </div>
            <div class="form-group">
                <label>Сумма</label>
                <input value="@_newOrder.Amount"
                       @oninput="OnAmountInput"
                       class="form-input" placeholder="0"/>
            </div>
            <div class="form-group">
                <label>Дата</label>
                <div class="date-combo">
                    <input type="text"
                           value="@_dateText"
                           @oninput="OnDateTextInput"
                           class="form-input"
                           placeholder="дд.мм.гггг"/>
                    <input type="date"
                           value="@_dateValue.ToString("yyyy-MM-dd")"
                           @oninput="OnDatePickerInput"
                           class="date-picker-btn"
                           title="Выбрать дату"/>
                </div>
            </div>
            <div class="form-group">
                <label>Комментарии</label>
                <textarea @bind="_newOrder.Comments" class="form-input" rows="3"></textarea>
            </div>
            <div class="form-group">
                <label>Автор заявки</label>
                <div class="author-display">@Session.Name</div>
            </div>
            @if (_addError != null)
            {
                <div class="alert-error">@_addError</div>
            }
            <div class="modal-buttons">
                <button class="btn-save" @onclick="AddOrder" disabled="@_saving">
                    @(_saving ? "Сохранение..." : "Сохранить")
                </button>
                <button class="btn-cancel" @onclick="CloseAdd">Отмена</button>
            </div>
        </div>
    </div>
}

<!-- Detail / Edit Modal -->
@if (_selected != null)
{
    <div class="modal-overlay" @onclick="CloseDetail">
        <div class="modal-box" @onclick:stopPropagation="true">
            <h3>Заявка №@_selected.OrderNumber</h3>

            @if (Session.Role == "Оператор")
            {
                <!-- Оператор: все поля редактируемые -->
                <div class="form-group">
                    <label>Адрес</label>
                    <input type="text" @bind="_editAddress" class="form-input" placeholder="Адрес"/>
                </div>
                <div class="form-group">
                    <label>Телефон</label>
                    <input id="edit-phone-input" type="tel"
                           value="@_editPhone"
                           @oninput="OnEditPhoneInput"
                           class="form-input" placeholder="+7..."/>
                </div>
                <div class="form-group">
                    <label>Сумма</label>
                    <input type="text" @bind="_editAmount" class="form-input" placeholder="0"/>
                </div>
                <div class="form-group">
                    <label>Дата</label>
                    <div class="date-combo">
                        <input type="text"
                               value="@_selectedDateText"
                               @oninput="OnDetailDateTextInput"
                               class="form-input"
                               placeholder="дд.мм.гггг"/>
                        <input type="date"
                               value="@(_selectedDateValue.ToString("yyyy-MM-dd"))"
                               @oninput="OnDetailDatePickerInput"
                               class="date-picker-btn"
                               title="Выбрать дату"/>
                    </div>
                </div>
                <div class="form-group">
                    <label>Комментарии</label>
                    <textarea @bind="_editComments" class="form-input" rows="3" placeholder="Комментарии..."></textarea>
                </div>
                <div class="form-group">
                    <label>Статус</label>
                    <select @bind="_selectedStatus" class="form-input">
                        <option>@OrderStatus.New</option>
                        <option>@OrderStatus.Completed</option>
                        <option>@OrderStatus.Cancelled</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Автор заявки</label>
                    <div class="author-display">@(string.IsNullOrEmpty(_selected.Author) ? "—" : _selected.Author)</div>
                </div>
                @if (!string.IsNullOrEmpty(_selected.Executor))
                {
                    <div class="form-group">
                        <label>Исполнитель</label>
                        <div class="author-display">@_selected.Executor</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_selected.TwoGisLink))
                {
                    <div style="margin-top:6px">
                        <a href="@_selected.TwoGisLink" target="_blank" class="link-2gis">🗺 Открыть в 2ГИС</a>
                    </div>
                }
            }
            else
            {
                <!-- Исполнитель: только просмотр + редактирование статуса и даты -->
                <table class="detail-table">
                    <tr><th>Адрес</th><td>@_selected.Address</td></tr>
                    <tr>
                        <th>Телефон</th>
                        <td>
                            @if (!string.IsNullOrEmpty(_selected.Phone))
                            {
                                <a href="@("https://wa.me/" + WaPhone(_selected.Phone))" target="_blank" class="wa-link">@_selected.Phone</a>
                            }
                        </td>
                    </tr>
                    <tr><th>Сумма</th><td>@_selected.Amount</td></tr>
                    <tr><th>Дата</th><td>@_selected.Date</td></tr>
                    <tr><th>Комментарии</th><td>@_selected.Comments</td></tr>
                    @if (!string.IsNullOrEmpty(_selected.Author))
                    {
                        <tr><th>Автор</th><td>@_selected.Author</td></tr>
                    }
                    @if (!string.IsNullOrEmpty(_selected.Executor))
                    {
                        <tr><th>Исполнитель</th><td>@_selected.Executor</td></tr>
                    }
                    <tr>
                        <th>2ГИС</th>
                        <td>
                            @if (!string.IsNullOrEmpty(_selected.TwoGisLink))
                            {
                                <a href="@_selected.TwoGisLink" target="_blank" class="link-2gis">Открыть карту</a>
                            }
                        </td>
                    </tr>
                </table>
                <div class="form-group" style="margin-top:16px">
                    <label>Дата</label>
                    <div class="date-combo">
                        <input type="text"
                               value="@_selectedDateText"
                               @oninput="OnDetailDateTextInput"
                               class="form-input"
                               placeholder="дд.мм.гггг"/>
                        <input type="date"
                               value="@(_selectedDateValue.ToString("yyyy-MM-dd"))"
                               @oninput="OnDetailDatePickerInput"
                               class="date-picker-btn"
                               title="Выбрать дату"/>
                    </div>
                </div>
                <div class="form-group">
                    <label>Статус</label>
                    <select @bind="_selectedStatus" class="form-input">
                        <option>@OrderStatus.New</option>
                        <option>@OrderStatus.Completed</option>
                        <option>@OrderStatus.Cancelled</option>
                    </select>
                </div>
            }

            @if (_detailError != null)
            {
                <div class="alert-error">@_detailError</div>
            }
            <div class="modal-buttons">
                @if (Session.Role == "Оператор")
                {
                    <button class="btn-save" @onclick="SaveOrder" disabled="@_saving">
                        @(_saving ? "Сохранение..." : "💾 Сохранить изменения")
                    </button>
                }
                else
                {
                    <button class="btn-save" @onclick="SaveStatus" disabled="@_saving">
                        @(_saving ? "Сохранение..." : "Сохранить статус")
                    </button>
                }
                <button class="btn-cancel" @onclick="CloseDetail">Закрыть</button>
            </div>
        </div>
    </div>
}

@code {
    List<Order>? _orders;
    bool _loading = false;
    string? _error;

    // Date filter
    DateTime? _filterDate;

    List<Order> Filtered => _orders == null ? new() :
        _filterDate.HasValue
            ? _orders.Where(o => o.Date == _filterDate.Value.ToString("dd.MM.yyyy")).ToList()
            : _orders;

    void OnFilterDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
            _filterDate = dt;
        else
            _filterDate = null;
    }

    void ClearDateFilter() => _filterDate = null;

    // Add modal
    bool _showAdd = false;
    Order _newOrder = new();
    string _phoneInput = "";
    DateTime _dateValue = DateTime.Today;
    string _dateText = DateTime.Today.ToString("dd.MM.yyyy");
    bool _saving = false;
    string? _addError;

    // Detail modal
    Order? _selected;
    string _selectedStatus   = "";
    string _selectedDateText = "";
    DateTime _selectedDateValue = DateTime.Today;
    // Поля редактирования для оператора
    string _editAddress  = "";
    string _editPhone    = "";
    string _editAmount   = "";
    string _editComments = "";
    string? _detailError;

    // Scroll restoration after poll re-render
    double _scrollPosToRestore = -1;

    // Bulk selection
    HashSet<int> _checkedRows = new();
    string _bulkStatus = "";
    bool _bulkSaving = false;
    int _bulkProgress = 0;
    string? _bulkError;

    void ToggleCheck(int rowIndex)
    {
        if (_checkedRows.Contains(rowIndex)) _checkedRows.Remove(rowIndex);
        else _checkedRows.Add(rowIndex);
    }

    void ToggleAll()
    {
        if (_checkedRows.Count == Filtered.Count)
            _checkedRows.Clear();
        else
            _checkedRows = Filtered.Select(o => o.RowIndex).ToHashSet();
    }

    void ClearChecked()
    {
        _checkedRows.Clear();
        _bulkStatus = "";
        _bulkError = null;
    }

    async Task ApplyBulkStatus()
    {
        if (string.IsNullOrEmpty(_bulkStatus) || _checkedRows.Count == 0) return;
        _bulkSaving = true;
        _bulkProgress = 0;
        _bulkError = null;
        try
        {
            var toUpdate = Filtered.Where(o => _checkedRows.Contains(o.RowIndex)).ToList();
            foreach (var o in toUpdate)
            {
                await Sheets.UpdateStatusAsync(o.RowIndex, _bulkStatus);
                _bulkProgress++;
                StateHasChanged();
            }
            ClearChecked();
            await LoadOrders();
        }
        catch (Exception ex) { _bulkError = "Ошибка: " + ex.Message; }
        finally { _bulkSaving = false; }
    }

    Timer? _pollTimer;
    int _lastOrderCount = 0;

    protected override async Task OnInitializedAsync() => await LoadOrders();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Запуск опроса новых заявок каждые 30 сек
            _pollTimer = new Timer(async _ => await InvokeAsync(PollOrders),
                null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
        // Восстановить позицию прокрутки после фонового обновления
        if (_scrollPosToRestore >= 0)
        {
            var pos = _scrollPosToRestore;
            _scrollPosToRestore = -1;
            try { await JS.InvokeVoidAsync("setScrollTop", ".table-wrapper", pos); } catch { }
        }
        // Маска телефона в модалке "Новая заявка" — вызываем каждый рендер пока открыта
        if (_showAdd)
        {
            try { await JS.InvokeVoidAsync("initPhoneMask", "phone-mask-input"); } catch { }
        }
        // Маска телефона в модалке редактирования (оператор)
        if (_selected != null && Session.Role == "Оператор")
        {
            try { await JS.InvokeVoidAsync("initPhoneMask", "edit-phone-input"); } catch { }
        }
    }

    async Task PollOrders()
    {
        try
        {
            var orders = await Sheets.GetOrdersAsync();
            if (_lastOrderCount > 0 && orders.Count > _lastOrderCount)
                await JS.InvokeVoidAsync("showNotify", "Новая заявка!", $"Добавлено заявок: {orders.Count - _lastOrderCount}");
            _lastOrderCount = orders.Count;
            if (_orders != null)
            {
                try { _scrollPosToRestore = await JS.InvokeAsync<double>("getScrollTop", ".table-wrapper"); } catch { }
                _orders = orders;
                StateHasChanged();
            }
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        if (_pollTimer != null) await _pollTimer.DisposeAsync();
    }

    async Task LoadOrders()
    {
        _loading = true;
        _error = null;
        try
        {
            _orders = await Sheets.GetOrdersAsync();
            _lastOrderCount = _orders?.Count ?? 0;
        }
        catch (Exception ex) { _error = "Ошибка загрузки: " + ex.Message; }
        finally { _loading = false; }
    }

    void OpenAdd()
    {
        _newOrder = new Order { Author = Session.Name };
        _phoneInput = "";
        _dateValue = DateTime.Today;
        _dateText = DateTime.Today.ToString("dd.MM.yyyy");
        _addError = null;
        _showAdd = true;
    }

    void OnDateTextInput(ChangeEventArgs e)
    {
        _dateText = e.Value?.ToString() ?? "";
        string[] formats = { "dd.MM.yyyy", "d.M.yyyy", "dd/MM/yyyy", "d/M/yyyy", "yyyy-MM-dd" };
        if (DateTime.TryParseExact(_dateText, formats,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out var dt))
            _dateValue = dt;
    }

    void OnDatePickerInput(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        {
            _dateValue = dt;
            _dateText = dt.ToString("dd.MM.yyyy");
        }
    }
    void CloseAdd() => _showAdd = false;

    // Подавляем re-render при наборе текста, чтобы не было мигания
    bool _suppressRender = false;
    protected override bool ShouldRender()
    {
        if (_suppressRender) { _suppressRender = false; return false; }
        return true;
    }

    void OnAddressInput(ChangeEventArgs e) { _suppressRender = true; _newOrder.Address = e.Value?.ToString() ?? ""; }
    void OnAmountInput(ChangeEventArgs e)  { _suppressRender = true; _newOrder.Amount  = e.Value?.ToString() ?? ""; }

    void OnPhoneInput(ChangeEventArgs e)
    {
        _suppressRender = true;
        _phoneInput = e.Value?.ToString() ?? "";
        _newOrder.Phone = FormatPhone(_phoneInput);
    }

    void OnEditPhoneInput(ChangeEventArgs e)
    {
        _suppressRender = true;
        _editPhone = e.Value?.ToString() ?? "";
    }

    async Task AddOrder()
    {
        if (string.IsNullOrWhiteSpace(_newOrder.Address))
        {
            _addError = "Укажите адрес.";
            return;
        }
        _saving = true;
        _addError = null;
        try
        {
            _newOrder.Date  = string.IsNullOrEmpty(_dateText) ? _dateValue.ToString("dd.MM.yyyy") : _dateText;
            _newOrder.Phone = FormatPhone(_newOrder.Phone);
            await Sheets.AddOrderAsync(_newOrder);
            _showAdd = false;
            await LoadOrders();
        }
        catch (Exception ex)
        {
            _addError = "Ошибка сохранения: " + ex.Message;
        }
        finally { _saving = false; }
    }

    void OpenDetail(Order o)
    {
        _selected = o;
        _selectedStatus   = o.Status;
        _selectedDateText = o.Date;
        if (DateTime.TryParseExact(o.Date, "dd.MM.yyyy",
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out var dt))
            _selectedDateValue = dt;
        else
            _selectedDateValue = DateTime.Today;
        // Поля для редактирования оператором
        _editAddress  = o.Address;
        _editPhone    = o.Phone;
        _editAmount   = o.Amount;
        _editComments = o.Comments;
        _detailError  = null;
    }
    void CloseDetail() => _selected = null;

    void OnDetailDateTextInput(ChangeEventArgs e)
    {
        _selectedDateText = e.Value?.ToString() ?? "";
        string[] formats = { "dd.MM.yyyy", "d.M.yyyy", "dd/MM/yyyy", "d/M/yyyy", "yyyy-MM-dd" };
        if (DateTime.TryParseExact(_selectedDateText, formats,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out var dt))
            _selectedDateValue = dt;
    }

    void OnDetailDatePickerInput(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        {
            _selectedDateValue = dt;
            _selectedDateText = dt.ToString("dd.MM.yyyy");
        }
    }

    // Сохранение для оператора: все поля заявки
    async Task SaveOrder()
    {
        if (_selected == null) return;
        if (string.IsNullOrWhiteSpace(_editAddress))
        {
            _detailError = "Укажите адрес.";
            return;
        }
        _saving = true;
        _detailError = null;
        try
        {
            var phone = FormatPhone(_editPhone);
            var date  = string.IsNullOrEmpty(_selectedDateText) ? _selected.Date : _selectedDateText;
            await Sheets.UpdateOrderAsync(
                _selected.RowIndex,
                _editAddress, phone, _editAmount,
                date, _selectedStatus, _editComments,
                _selected.Executor, _selected.Author);
            CloseDetail();
            await LoadOrders();
        }
        catch (Exception ex) { _detailError = "Ошибка: " + ex.Message; }
        finally { _saving = false; }
    }

    // Сохранение для исполнителя: только статус и дата
    async Task SaveStatus()
    {
        if (_selected == null) return;
        bool statusChanged = _selectedStatus != _selected.Status;
        bool dateChanged   = !string.IsNullOrEmpty(_selectedDateText) && _selectedDateText != _selected.Date;
        if (!statusChanged && !dateChanged) { CloseDetail(); return; }
        _saving = true;
        _detailError = null;
        try
        {
            var executorName = Session.Role == "Исполнитель" ? Session.Name : "";
            var newDate = dateChanged ? _selectedDateText : "";
            await Sheets.UpdateStatusAsync(_selected.RowIndex, _selectedStatus, executorName, newDate);
            _selected.Status = _selectedStatus;
            if (dateChanged) _selected.Date = _selectedDateText;
            CloseDetail();
            await LoadOrders();
        }
        catch (Exception ex) { _detailError = "Ошибка: " + ex.Message; }
        finally { _saving = false; }
    }

    static string RowClass(string status) => status switch
    {
        OrderStatus.Completed => "row-green",
        OrderStatus.Cancelled => "row-red",
        _ => "row-blue"
    };

    static string StatusClass(string status) => status switch
    {
        OrderStatus.Completed => "status-green",
        OrderStatus.Cancelled => "status-red",
        _ => "status-blue"
    };

    static string WaPhone(string phone) =>
        new string(phone.Where(char.IsDigit).ToArray());

    static string FormatPhone(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return input;
        var digits = new string(input.Where(char.IsDigit).ToArray());
        if (string.IsNullOrEmpty(digits)) return input;
        if (digits.StartsWith("8")) digits = "7" + digits[1..];
        if (!digits.StartsWith("7") && digits.Length == 10) digits = "7" + digits;
        if (digits.StartsWith("7") && digits.Length == 11)
            return $"+7{digits[1..4]} {digits[4..7]} {digits[7..9]} {digits[9..11]}";
        if (digits.StartsWith("7")) return "+" + digits;
        return input;
    }
}
