@page "/map"
@implements IAsyncDisposable
@inject GoogleSheetsService Sheets
@inject UserSession Session
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (!Session.IsAuthenticated)
{
    Nav.NavigateTo("/");
    return;
}

<div class="map-page">

    <!-- Mobile tab switcher (visible only on mobile) -->
    <div class="mobile-tabs">
        <button class="mobile-tab @(!_mobileMapView ? "active" : "")" @onclick="ShowList">
            📋 Список (@_filtered.Count)
        </button>
        <button class="mobile-tab @(_mobileMapView ? "active" : "")" @onclick="ShowMap">
            🗺 Карта
        </button>
    </div>

    <!-- Sidebar: always visible on desktop, toggleable on mobile -->
    <div class="map-sidebar @(_mobileMapView ? "mobile-hidden" : "")">
        <div class="map-sidebar-header">
            <h3>Невыполненные заявки</h3>
            <div class="form-group" style="margin-bottom:0">
                <label style="font-size:0.8rem;color:#666">Фильтр по дате</label>
                <input type="date"
                       value="@(_filterDate.ToString("yyyy-MM-dd"))"
                       @oninput="OnDateChanged"
                       class="form-input"
                       style="padding:6px 10px"/>
                @if (_filterActive)
                {
                    <button class="btn-clear-date" @onclick="ClearDate">✕ Все даты</button>
                }
            </div>
        </div>

        @if (_loading)
        {
            <div class="loading-text">Загрузка...</div>
        }
        else if (_error != null)
        {
            <div class="alert-error">@_error</div>
        }
        else if (_filtered.Count == 0)
        {
            <div class="loading-text">Нет заявок на выбранную дату</div>
        }
        else
        {
            <div class="map-order-count">Заявок: @_filtered.Count</div>
            @if (_filtered.Count > 0)
            {
                <button class="btn-route" @onclick="BuildRoute" disabled="@(_geocoding || _routeBuilding)">
                    @if (_routeBuilding)
                    { <span>Открываю маршрут...</span> }
                    else if (_geocoding)
                    { <span>Ожидайте геокодирование...</span> }
                    else
                    { <span>🗺 Маршрут в 2ГИС (@_filtered.Count адр.)</span> }
                </button>
                @if (_routeMsg != null)
                {
                    <div class="route-msg">@_routeMsg</div>
                }
            }
            <div class="map-order-list">
                @foreach (var o in _filtered)
                {
                    <div class="map-order-item @(_selected?.RowIndex == o.RowIndex ? "active" : "")"
                         @onclick="() => SelectOrder(o)">
                        <div class="map-order-num">№@o.OrderNumber</div>
                        <div class="map-order-addr">@o.Address</div>
                        <div class="map-order-meta">
                            @o.Date ·
                            @if (!string.IsNullOrEmpty(o.Phone))
                            {
                                <a href="@("https://wa.me/" + WaPhone(o.Phone))" target="_blank" class="wa-link" @onclick:stopPropagation="true">@o.Phone</a>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(o.Amount))
                        {
                            <div class="map-order-amount">@o.Amount ₸</div>
                        }
                        @if (!string.IsNullOrEmpty(o.Comments))
                        {
                            <div class="map-order-comment">💬 @o.Comments</div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <!-- Map: always visible on desktop, toggleable on mobile -->
    <div class="map-main @(!_mobileMapView ? "mobile-hidden" : "")">
        @if (_selected != null)
        {
            <div class="map-info-panel">
                <strong>№@_selected.OrderNumber</strong> — @_selected.Address
                @if (!string.IsNullOrEmpty(_selected.Phone))
                {
                    <span> · <a href="@("https://wa.me/" + WaPhone(_selected.Phone))" target="_blank" class="wa-link">@_selected.Phone</a></span>
                }
                <button class="map-info-close" @onclick="() => _selected = null">✕</button>
            </div>
        }
        <div id="map-container"></div>
        @if (_geocoding)
        {
            <div class="map-loading-overlay">Геокодирование адресов...</div>
        }
    </div>
</div>

@code {
    List<Order> _allOrders = new();
    List<Order> _filtered  = new();
    Order? _selected;
    bool _loading  = true;
    bool _geocoding = false;
    string? _error;
    DateTime _filterDate = DateTime.Today;
    bool _filterActive   = true;
    bool _mobileMapView  = false;
    DotNetObjectReference<Map>? _dotNetRef;
    bool _mapInitialized = false;
    bool _routeBuilding  = false;
    string? _routeMsg;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) return;
        await LoadOrders();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Инициализируем карту как только данные загружены и DOM готов
        if (!_mapInitialized && !_loading && _error == null)
        {
            _mapInitialized = true;
            await InitMap();
        }
    }

    async Task LoadOrders()
    {
        _loading = true;
        _error = null;
        try
        {
            var all = await Sheets.GetOrdersAsync();
            _allOrders = all.Where(o => o.Status == OrderStatus.New).ToList();
            ApplyFilter();
        }
        catch (Exception ex) { _error = "Ошибка: " + ex.Message; }
        finally
        {
            _loading = false;
            StateHasChanged(); // явно вызываем перерендер, чтобы OnAfterRenderAsync инициализировал карту
        }
    }

    void ApplyFilter()
    {
        _filtered = _filterActive
            ? _allOrders.Where(o => o.Date == _filterDate.ToString("dd.MM.yyyy")).ToList()
            : _allOrders.ToList();
    }

    async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        {
            _filterDate = dt;
            _filterActive = true;
        }
        ApplyFilter();
        _mapInitialized = false;
        await InitMap();
    }

    async Task ClearDate()
    {
        _filterDate = DateTime.Today;
        _filterActive = false;
        ApplyFilter();
        _mapInitialized = false;
        await InitMap();
    }

    async Task InitMap()
    {
        if (_geocoding) return;
        _geocoding = true;
        StateHasChanged();
        try
        {
            _dotNetRef?.Dispose();
            _dotNetRef = DotNetObjectReference.Create(this);
            var orders = _filtered.Select(o => new
            {
                orderNumber = o.OrderNumber,
                address     = o.Address,
                phone       = o.Phone,
                amount      = o.Amount,
                date        = o.Date,
                comments    = o.Comments,
                twoGisLink  = o.TwoGisLink
            }).ToList();
            await JS.InvokeVoidAsync("mapInit", orders, _dotNetRef);
        }
        catch (Exception ex) { _error = "Ошибка карты: " + ex.Message; }
        finally { _geocoding = false; StateHasChanged(); }
    }

    [JSInvokable]
    public void OnMarkerClick(int orderNumber)
    {
        _selected = _filtered.FirstOrDefault(o => o.OrderNumber == orderNumber);
        _mobileMapView = true;
        StateHasChanged();
    }

    void ShowList()
    {
        _mobileMapView = false;
        StateHasChanged();
    }

    async Task ShowMap()
    {
        _mobileMapView = true;
        StateHasChanged();
        await Task.Delay(150);
        try { await JS.InvokeVoidAsync("mapInvalidateSize"); } catch { }
        if (!_mapInitialized && !_loading)
        {
            _mapInitialized = true;
            await InitMap();
        }
    }

    async Task SelectOrder(Order o)
    {
        _selected = o;
        await ShowMap();
        await Task.Delay(200);
        try { await JS.InvokeVoidAsync("mapFlyTo", o.OrderNumber); } catch { }
    }

    async Task BuildRoute()
    {
        _routeMsg = null;
        _routeBuilding = true;
        try
        {
            var orders = _filtered.Select(o => new { orderNumber = o.OrderNumber, address = o.Address }).ToArray();
            var count = await JS.InvokeAsync<int>("mapBuildRoute", new object[] { orders });
            if (count == 0)
                _routeMsg = "Нет адресов для построения маршрута.";
        }
        catch (Exception ex) { _routeMsg = "Ошибка: " + ex.Message; }
        finally { _routeBuilding = false; }
    }

    static string WaPhone(string phone) =>
        new string(phone.Where(char.IsDigit).ToArray());

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("mapDestroy"); } catch { }
        _dotNetRef?.Dispose();
    }
}
